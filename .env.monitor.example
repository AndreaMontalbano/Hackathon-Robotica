# InterHuman AI operator monitor — copy the needed line into your existing .env
# (this file is additive; it does NOT replace .env.example)
#
#   cat .env.monitor.example >> .env     # then edit the value
#
# Get an API key from the InterHuman dashboard.
INTERHUMAN_API_KEY=your_interhuman_api_key_here

# Optional: webcam index for the face stream (default 0).
# In the standalone monitor this is the camera it opens itself.
# INTERHUMAN_CAMERA=0

# Optional: mini-clip length in seconds sent per analysis segment (default 2.0).
# INTERHUMAN_CHUNK_SECONDS=2.0
